{
  "name": "asurascans-dl",
  "version": "1.3.1",
  "description": "CLI tool to download manhwa from Asura Scans",
  "packageManager": "bun@1.3.11",
  "main": "dist/cli.js",
  "bin": {
    "asurascans-dl": "dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "sync:version": "bun run ./scripts/sync-version.mjs",
    "build": "bun run sync:version && bun run tsc",
    "build:bundle": "bun build ./src/cli.ts --target=node --outfile ./dist/cli.js",
    "start": "bun run sync:version && bun run ./src/cli.ts",
    "dev": "bun run sync:version && bun run ./src/cli.ts",
    "release:build": "bun run sync:version && bun run ./scripts/build-release.mjs",
    "typecheck": "bun run sync:version && bun run tsc --noEmit",
    "test": "bun run sync:version && bun test"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "p-limit": "^6.2.0",
    "sharp": "^0.33.5",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/yazl": "^3.3.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "bun": ">=1.3.11"
  }
}